# ============================================================
# TMKI RAG CONFIG v0.1
# ============================================================

# ---------- Ollama ----------
OLLAMA_URL=http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_LLM_MODEL=qwen2.5:7b
OLLAMA_MODEL=qwen2.5:7b

# ---------- Embeddings ----------
TMKI_EMBEDDING_PROVIDER=ollama
TMKI_EMBEDDING_MODEL=nomic-embed-text
TMKI_EMBEDDING_DIM=768
TMKI_EMBEDDING_DIMS=768

# ---------- Chunking (Docling) ----------
TMKI_CHUNK_SIZE=1024
TMKI_CHUNK_OVERLAP=128
TMKI_CHUNK_SPLIT_BY_HEADERS=true
TMKI_CHUNK_SPLIT_BY_TABLES=false
TMKI_CHUNK_SPLIT_BY_LISTS=false

# ---------- RAG Search ----------
TMKI_RAG_TOP_K=20          # кандидатов до rerank
TMKI_RAG_FINAL_K=5         # после rerank
TMKI_RAG_FUSION=1
TMKI_RAG_FUSION_LLM=1

# ---------- Rerank ----------
TMKI_RERANK_ENABLED=1
TMKI_RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
TMKI_RERANK_TOP_K=5
TMKI_CROSS_ENCODER_RERANK=1
TMKI_CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ---------- System Prompt ----------
TMKI_SYSTEM_PROMPT_PATH=prompts/system_prompt.txt

# ---------- SKRU-2 load tuning ----------
TMKI_EMBED_BATCH=48
TMKI_LOAD_WORKERS=8

# ---------- Database ----------
DATABASE_URL=postgresql://postgres:ВАШ_ПАРОЛЬ@localhost:5433/tmki
TMKI_INDEX_BACKEND=pgvector
TMKI_PGVECTOR_TABLE=chunks

# ---------- Ingest / Parser ----------
# Режим парсинга документов:
#   default - pypdf → PyMuPDF → Tesseract (локальный OCR)
#   docling - Docling + pypdfium2 (таблицы, структура)
#   kreuzberg - Kreuzberg (легковесный, быстрый)
TMKI_INGEST_PARSER=default

# ---------- OCR Mode ----------
# Режим OCR:
#   local - локальный Tesseract
#   http  - облачный API (MinerU, Mistral)
TMKI_OCR_MODE=local

# ---------- Cloud OCR (если TMKI_OCR_MODE=http) ----------
# MINERU_API_URL=https://api.mineru.com/v1
# MINERU_API_KEY=your_key_here
# MISTRAL_API_KEY=your_key_here

# ---------- Demo ----------
TMKI_DEMO_PORT=8770
TMKI_DEMO_HOST=127.0.0.1

# ---------- Logging ----------
TMKI_LOG_LEVEL=INFO
TMKI_LOG_FILE=logs/rag.log
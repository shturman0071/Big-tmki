# ============================================================
# TMKI RAG CONFIG v0.1
# ============================================================

# ---------- Ollama ----------
OLLAMA_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_LLM_MODEL=qwen2.5:7b

# ---------- Embeddings ----------
TMKI_EMBEDDING_PROVIDER=ollama
TMKI_EMBEDDING_MODEL=nomic-embed-text
TMKI_EMBEDDING_DIM=768

# ---------- Chunking (Docling) ----------
TMKI_CHUNK_SIZE=1024
TMKI_CHUNK_OVERLAP=128
TMKI_CHUNK_SPLIT_BY_HEADERS=true
TMKI_CHUNK_SPLIT_BY_TABLES=false
TMKI_CHUNK_SPLIT_BY_LISTS=false

# ---------- RAG Search ----------
TMKI_RAG_TOP_K=20          # кандидатов до rerank
TMKI_RAG_FINAL_K=5         # после rerank
TMKI_RAG_FUSION=1
TMKI_RAG_FUSION_LLM=1

# ---------- Rerank ----------
TMKI_RERANK_ENABLED=1
TMKI_RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
TMKI_RERANK_TOP_K=5

# ---------- System Prompt ----------
TMKI_SYSTEM_PROMPT_PATH=prompts/system_prompt.txt

# ---------- Database ----------
DATABASE_URL=postgresql://postgres:ВАШ_ПАРОЛЬ@localhost:5433/tmki

# ---------- Demo ----------
TMKI_DEMO_PORT=8767
TMKI_DEMO_HOST=0.0.0.0

# ---------- Logging ----------
TMKI_LOG_LEVEL=INFO
TMKI_LOG_FILE=logs/rag.log

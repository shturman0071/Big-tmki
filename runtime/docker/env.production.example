# Production-like local stack (docker compose -f docker-compose.full.yml up -d)
DATABASE_URL=postgresql://tmki:tmki_dev@127.0.0.1:5432/tmki
TMKI_INDEX_BACKEND=pgvector
TMKI_EMBEDDING_PROVIDER=local
TMKI_EMBEDDING_DIMS=64
TMKI_OCR_MODE=local
# HTTP OCR: TMKI_OCR_MODE=http + endpoints (python scripts/check_ocr_http.py)
# MINERU_API_URL=
# MINERU_API_KEY=
# MISTRAL_OCR_API_URL=
# MISTRAL_API_KEY=
TMKI_LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b
TMKI_GRAPH_DRY_RUN=1

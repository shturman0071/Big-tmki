# Опциональные профили TMKI (скопируйте нужные строки в secrets.local)
# Затем: python scripts/merge_env.py  и перезапустите демо.

# --- Retrieval (уже включено по умолчанию в merge_env.py) ---
# TMKI_RAG_FUSION=1
# TMKI_CROSS_ENCODER_RERANK=1
# TMKI_QUALITY_RERANK=1
# TMKI_INCREMENTAL_INGEST=1

# --- Перефразировки RAG Fusion через Ollama (медленнее, точнее) ---
# Требует: ollama serve + модель OLLAMA_MODEL
# TMKI_RAG_FUSION_LLM=1

# --- Ingest-парсер (вместо pypdf/tesseract) ---
# pip install -e ".[ingest-docling]"   затем:
# TMKI_INGEST_PARSER=docling
# pip install kreuzberg                 затем:
# TMKI_INGEST_PARSER=kreuzberg

# --- Postgres + pgvector (СКРУ-2 в демо) ---
# docker compose -f docker/docker-compose.yml up -d
# pip install -e ".[pgvector]"
# DATABASE_URL=postgresql://tmki:tmki_dev@127.0.0.1:5432/tmki
# TMKI_INDEX_BACKEND=pgvector
# python scripts/load_regulations_pgvector.py --variant v2

# Скопируйте в runtime/.env и вставьте свой ключ (файл .env не коммитится).
# cp env.demo.example .env   (или вручную в Блокноте)

# Облачная LLM — только для корпуса «Армировка КС»
OPENAI_API_KEY=sk-...

# Опционально: модель OpenAI (по умолчанию gpt-4o-mini в providers.py)
# OPENAI_MODEL=gpt-4o-mini

# Архивы (уже заданы в run_tmki_demo_ui.ps1, можно переопределить)
# TMKI_REGULATIONS_ARCHIVE=D:\Курсор\СКРУ-2
# TMKI_ARM_KS_ARCHIVE=D:\Курсор\Армировка КС

# OCR: local (pypdf/docx) | http (MinerU/Mistral для сканов) | stub
# TMKI_OCR_MODE=local
# См. env.ocr.example и scripts/setup_ocr.ps1

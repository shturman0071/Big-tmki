# OCR-настройки для runtime/.env (не коммитить .env)
# cp env.ocr.example .env  и дополните ключи

# local — pypdf/docx без внешнего API (PDF только с текстовым слоем)
# http  — MinerU + Mistral OCR fallback (сканы, фото-PDF)
# stub  — mock для тестов
TMKI_OCR_MODE=local

# Лимит страниц PDF при local-извлечении (по умолчанию 300)
# TMKI_PDF_MAX_PAGES=300

# HTTP OCR (нужно при TMKI_OCR_MODE=http)
# Облако MinerU: https://mineru.net/api/v4 + токен из user-center
MINERU_API_URL=https://mineru.net/api/v4
MINERU_API_KEY=
# Mistral OCR: https://docs.mistral.ai/api/endpoint/ocr
MISTRAL_OCR_API_URL=https://api.mistral.ai/v1/ocr
MISTRAL_API_KEY=
MISTRAL_OCR_MODEL=mistral-ocr-latest

# Таймауты и ретраи HTTP OCR
# TMKI_OCR_HTTP_RETRIES=1
# TMKI_OCR_HTTP_RETRY_DELAY_MS=500

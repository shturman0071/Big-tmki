# Скопируйте в runtime/secrets.local (не коммитится) и вставьте ключ.
# Затем: python scripts/merge_env.py  и перезапустите демо.

OPENAI_API_KEY=sk-...   # реальный ключ с https://platform.openai.com/account/api-keys
TMKI_LLM_PROVIDER=openai
OPENAI_MODEL=gpt-4o-mini

# OCR: локальный Tesseract (сканы) или http при наличии MISTRAL_API_KEY
TMKI_OCR_MODE=local

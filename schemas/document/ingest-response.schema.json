{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tmki.dev/schemas/document/ingest-response.schema.json",
  "title": "TMKI Document Ingest Response",
  "description": "Ingest API response including dedup outcome (v0.1)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "trace_id",
    "ingest_status",
    "content_hash",
    "occurred_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1"
    },
    "trace_id": {
      "type": "string",
      "format": "uuid"
    },
    "ingest_status": {
      "type": "string",
      "enum": [
        "accepted",
        "duplicate",
        "rejected",
        "processing",
        "completed",
        "failed"
      ]
    },
    "doc_id": {
      "type": "string",
      "description": "Stable document id (existing or newly assigned)"
    },
    "content_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "description": "SHA-256 of raw file bytes"
    },
    "dedup": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "is_duplicate": { "type": "boolean" },
        "matched_doc_id": { "type": "string" },
        "dedup_key": {
          "type": "string",
          "description": "company_id:project_id:content_hash"
        },
        "action": {
          "type": "string",
          "enum": ["skipped_processing", "linked_existing", "reprocessed", "none"]
        }
      }
    },
    "job_id": {
      "type": "string",
      "description": "Async pipeline job id when status=processing"
    },
    "error": {
      "$ref": "../runtime/common.schema.json#/$defs/runtimeError"
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "ingest_status": { "enum": ["duplicate", "accepted", "processing", "completed"] } },
        "required": ["ingest_status"]
      },
      "then": { "required": ["doc_id"] }
    }
  ]
}

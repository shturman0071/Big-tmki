{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tmki.dev/schemas/org/employee-folder-grant.schema.json",
  "title": "TMKI — grant/deny доступа к папке",
  "description": "Персональное делегирование начальником подразделения (v0.1)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "grant_id",
    "grant_type",
    "employee_id",
    "folder_id",
    "department_id",
    "granted_by_employee_id",
    "actions",
    "valid_from",
    "status"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "0.1" },
    "grant_id": { "$ref": "common.schema.json#/$defs/entityId" },
    "grant_type": {
      "type": "string",
      "enum": ["grant", "deny"]
    },
    "employee_id": { "$ref": "common.schema.json#/$defs/entityId" },
    "folder_id": {
      "type": "string",
      "pattern": "^folder_[a-z][a-z0-9_]{1,63}$"
    },
    "department_id": { "$ref": "common.schema.json#/$defs/entityId" },
    "granted_by_employee_id": { "$ref": "common.schema.json#/$defs/entityId" },
    "actions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["read", "write"]
      },
      "description": "delete MUST NOT выдаваться рядовому составу через grant"
    },
    "valid_from": { "$ref": "common.schema.json#/$defs/date" },
    "valid_to": { "$ref": "common.schema.json#/$defs/date" },
    "status": {
      "type": "string",
      "enum": ["active", "revoked", "expired"]
    },
    "reason": {
      "type": "string",
      "maxLength": 500,
      "description": "MAY: комментарий для audit"
    }
  },
  "allOf": [
    {
      "if": { "properties": { "grant_type": { "const": "deny" } } },
      "then": {
        "properties": {
          "actions": {
            "contains": { "const": "read" },
            "maxItems": 2
          }
        }
      }
    }
  ]
}

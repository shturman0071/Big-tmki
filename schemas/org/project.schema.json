{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tmki.dev/schemas/org/project.schema.json",
  "title": "TMKI — проект",
  "description": "Проектная сущность (например, строительство шахты Сатимол) (v0.1)",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "project_id", "name", "primary_company_id", "status"],
  "properties": {
    "schema_version": { "type": "string", "const": "0.1" },
    "project_id": { "$ref": "common.schema.json#/$defs/entityId" },
    "name": { "$ref": "common.schema.json#/$defs/localizedLabel" },
    "primary_company_id": {
      "$ref": "common.schema.json#/$defs/entityId",
      "description": "Operating company (e.g. company_tmki_ru)"
    },
    "company_ids": {
      "type": "array",
      "items": { "$ref": "common.schema.json#/$defs/entityId" },
      "description": "All participating legal entities"
    },
    "status": { "$ref": "common.schema.json#/$defs/entityStatus" },
    "started_on": { "$ref": "common.schema.json#/$defs/date" }
  }
}

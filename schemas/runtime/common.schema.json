{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tmki.dev/schemas/runtime/common.schema.json",
  "title": "TMKI Common Types",
  "description": "Общие типы для runtime, policy_context, citation, budget, circuit breaker",
  "$defs": {
    "clearanceLevel": {
      "type": "string",
      "enum": ["public", "internal", "restricted", "confidential"],
      "description": "Уровень доступа: public < internal < restricted < confidential"
    },
    "uuid": {
      "type": "string",
      "format": "uuid",
      "description": "RFC 4122 UUID"
    },
    "dateTime": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp (UTC recommended)"
    },
    "policyContext": {
      "type": "object",
      "description": "Session policy context (see ORG_MODEL.md)",
      "additionalProperties": false,
      "required": [
        "company_id",
        "project_id",
        "project_role",
        "employee_id",
        "clearance",
        "env"
      ],
      "properties": {
        "company_id": { "type": "string", "minLength": 1, "description": "ID юрлица (TMKI, Thyssen Schachtbau)" },
        "company_group_id": {
          "type": "string",
          "description": "ID группы (например, schbk)"
        },
        "project_id": { "type": "string", "minLength": 1, "description": "ID проекта (например, satimol)" },
        "department_id": { "type": "string", "description": "ID подразделения" },
        "position_id": {
          "type": "string",
          "description": "ID должности (Position) для определения is_manager"
        },
        "is_manager": {
          "type": "boolean",
          "default": false,
          "description": "Начальник подразделения? (вычисляется из Position)"
        },
        "project_role": { "type": "string", "minLength": 1, "description": "Проектная роль (Direktor, Projektleiter, ГИП и т.д.)" },
        "employee_id": { "type": "string", "minLength": 1, "description": "ID сотрудника" },
        "clearance": {
          "$ref": "#/$defs/clearanceLevel",
          "description": "Уровень доступа сотрудника"
        },
        "env": {
          "type": "string",
          "enum": ["development", "staging", "production"],
          "description": "Окружение"
        },
        "contractor_id": {
          "type": "string",
          "description": "ID подрядчика (для external-ролей)"
        }
      }
    },
    "tokenUsage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "prompt_tokens": { "type": "integer", "minimum": 0 },
        "completion_tokens": { "type": "integer", "minimum": 0 },
        "total_tokens": { "type": "integer", "minimum": 0 },
        "estimated_cost_usd": { "type": "number", "minimum": 0 }
      }
    },
    "budget": {
      "type": "object",
      "description": "Run-level limits (Loop Engine)",
      "additionalProperties": false,
      "properties": {
        "max_steps": { "type": "integer", "minimum": 1, "default": 10 },
        "max_tokens": { "type": "integer", "minimum": 1, "default": 32000 },
        "max_cost_usd": { "type": "number", "minimum": 0, "default": 2.5 },
        "timeout_ms": { "type": "integer", "minimum": 1, "default": 120000 },
        "max_step_duration_ms": { "type": "integer", "minimum": 1, "default": 60000 },
        "max_retries_per_step": { "type": "integer", "minimum": 0, "default": 2 }
      }
    },
    "circuitBreakerConfig": {
      "type": "object",
      "description": "Circuit breaker thresholds (Loop Engine)",
      "additionalProperties": false,
      "properties": {
        "consecutive_step_failures": { "type": "integer", "minimum": 1, "default": 3 },
        "same_error_code_threshold": { "type": "integer", "minimum": 1, "default": 2 },
        "same_tool_failure_threshold": { "type": "integer", "minimum": 1, "default": 2 },
        "recovery_mode": {
          "type": "string",
          "enum": ["degraded_readonly", "fail_run"],
          "default": "degraded_readonly"
        }
      }
    },
    "citation": {
      "type": "object",
      "description": "Citable fragment (see 09_document_processing.md)",
      "additionalProperties": false,
      "required": ["doc_id", "page"],
      "properties": {
        "doc_id": { "type": "string", "description": "ID документа" },
        "page": { "type": "integer", "minimum": 1, "description": "Номер страницы" },
        "start_offset": { "type": "integer", "minimum": 0, "description": "Начало цитаты в символах" },
        "end_offset": { "type": "integer", "minimum": 0, "description": "Конец цитаты в символах" },
        "snippet": { "type": "string", "description": "Текст цитаты" },
        "url": { "type": "string", "format": "uri", "description": "Ссылка на документ (опционально)" },
        "file_name": { "type": "string", "description": "Имя файла источника (demo/UI)" },
        "relative_path": { "type": "string", "description": "Путь в архиве регламентов" },
        "absolute_path": { "type": "string", "description": "Абсолютный путь к файлу (локальный demo)" }
      }
    },
    "runtimeError": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" },
        "retryable": { "type": "boolean", "default": false },
        "details": { "type": "object", "additionalProperties": true }
      }
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["user", "system", "service"]
        },
        "employee_id": { "type": "string" },
        "service_name": { "type": "string" }
      }
    }
  }
}
